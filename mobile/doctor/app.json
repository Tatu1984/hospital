{
  "expo": {
    "name": "Hospital — Doctor",
    "slug": "hospital-doctor",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hospitaldoctor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hospital.doctor",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Face ID is used to quickly unlock your account between sessions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.hospital.doctor"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-local-authentication", { "faceIDPermission": "Use Face ID to quickly sign in." }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
