{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "./node_modules/.bin/prisma generate",
  "installCommand": "npm ci --include=dev",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
