{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "./node_modules/.bin/prisma generate && node scripts/migrate.js",
  "installCommand": "npm ci --include=dev",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/audit-retention/run",
      "schedule": "30 2 * * *"
    }
  ]
}
