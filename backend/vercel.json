{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node node_modules/prisma/build/index.js generate",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
