// ===========================
// BLOOD BANK SYSTEM
// ===========================

model BloodDonor {
  id              String          @id @default(uuid())
  tenantId        String
  donorId         String
  name            String
  age             Int
  gender          String
  bloodType       String
  phone           String
  email           String?
  address         String?
  lastDonationAt  DateTime?
  totalDonations  Int             @default(0)
  isEligible      Boolean         @default(true)
  screeningStatus String          @default("pending") // pending, cleared, rejected
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  donations       BloodDonation[]

  @@unique([tenantId, donorId])
  @@index([tenantId])
  @@map("blood_donors")
}

model BloodDonation {
  id           String          @id @default(uuid())
  tenantId     String
  donorId      String
  donationDate DateTime        @default(now())
  bloodType    String
  component    String          @default("whole_blood")
  volume       Int             @default(450) // ml
  bagNumber    String
  collectedBy  String?
  status       String          @default("collected") // collected, processed, available, expired, discarded
  expiryDate   DateTime
  createdAt    DateTime        @default(now())
  donor        BloodDonor      @relation(fields: [donorId], references: [id])
  inventory    BloodInventory?

  @@unique([tenantId, bagNumber])
  @@index([tenantId])
  @@map("blood_donations")
}

model BloodInventory {
  id             String          @id @default(uuid())
  tenantId       String
  donationId     String?         @unique
  bloodType      String
  component      String
  bagNumber      String
  volume         Int
  collectionDate DateTime
  expiryDate     DateTime
  status         String          @default("available") // available, reserved, issued, expired, discarded
  location       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  donation       BloodDonation?  @relation(fields: [donationId], references: [id])
  issuances      BloodIssuance[]

  @@unique([tenantId, bagNumber])
  @@index([bloodType, component, status])
  @@index([tenantId])
  @@map("blood_inventory")
}

model BloodRequest {
  id               String          @id @default(uuid())
  tenantId         String
  patientId        String?
  patientName      String
  patientMRN       String?
  bloodType        String
  component        String
  unitsRequested   Int
  urgency          String          @default("routine") // routine, urgent, emergency
  indication       String?
  requestedBy      String?
  requestedAt      DateTime        @default(now())
  crossMatchedAt   DateTime?
  crossMatchedBy   String?
  crossMatchResult String? // compatible, incompatible
  status           String          @default("pending") // pending, crossmatched, approved, issued, cancelled
  remarks          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  issuances        BloodIssuance[]

  @@index([tenantId])
  @@map("blood_requests")
}

model BloodIssuance {
  id          String         @id @default(uuid())
  tenantId    String
  requestId   String
  inventoryId String
  issuedAt    DateTime       @default(now())
  issuedBy    String?
  receivedBy  String?
  status      String         @default("issued") // issued, returned, transfused
  remarks     String?
  createdAt   DateTime       @default(now())
  request     BloodRequest   @relation(fields: [requestId], references: [id])
  inventory   BloodInventory @relation(fields: [inventoryId], references: [id])

  @@index([tenantId])
  @@map("blood_issuances")
}

// ===========================
// HR & EMPLOYEE MANAGEMENT
// ===========================

model Employee {
  id          String               @id @default(uuid())
  tenantId    String
  branchId    String?
  employeeId  String
  name        String
  email       String?
  phone       String?
  department  String?
  designation String?
  joiningDate DateTime?
  salary      Decimal?             @db.Decimal(12, 2)
  status      String               @default("active") // active, on_leave, terminated
  shift       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  leaves      LeaveRequest[]
  attendances EmployeeAttendance[]

  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@map("employees")
}

model EmployeeAttendance {
  id         String    @id @default(uuid())
  tenantId   String
  employeeId String
  date       DateTime  @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     String    @default("present") // present, absent, half_day, on_leave
  remarks    String?
  createdAt  DateTime  @default(now())
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([tenantId])
  @@map("employee_attendances")
}

model LeaveRequest {
  id         String    @id @default(uuid())
  tenantId   String
  employeeId String
  leaveType  String // sick, casual, earned, maternity, etc.
  fromDate   DateTime
  toDate     DateTime
  // Working days requested (excludes Sundays + holidays). Derived at
  // creation from from/to range; payroll uses this to count paid-leave
  // days in the period. Null for legacy rows; backfilled lazily.
  days       Decimal?  @db.Decimal(5, 1)
  reason     String?
  status     String    @default("pending") // pending, approved, rejected, cancelled
  approvedBy String?
  approvedAt DateTime?
  remarks    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("leave_requests")
}

// Per-employee leave entitlement and consumption, scoped to a year.
// One row per (employee, leaveType, year). On approval of a LeaveRequest
// the matching balance row's `used` field bumps and `available` drops.
// On rejection / cancellation the inverse. Admin can adjust via the
// admin endpoint to seed annual entitlements at year-start.
model LeaveBalance {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  leaveType  String // sick, casual, earned, maternity, ...
  year       Int
  entitled   Decimal  @db.Decimal(5, 1) // annual allotment
  used       Decimal  @default(0) @db.Decimal(5, 1)
  carriedFwd Decimal  @default(0) @db.Decimal(5, 1) // earned-leave carryover
  // Optional cap on how many days can be encashed at year-end.
  encashable Decimal? @db.Decimal(5, 1)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, leaveType, year])
  @@index([tenantId])
  @@index([employeeId])
  @@map("leave_balances")
}

// One payslip per employee per pay period. Generated by /api/payroll/
// generate which consults EmployeeAttendance + LeaveRequest for the
// month and computes worked days, paid-leave days, LOP days, gross,
// deductions, and net. Persisted (not recomputed on every read) so
// historical payslips don't drift if attendance is later corrected.
model Payslip {
  id              String    @id @default(uuid())
  tenantId        String
  employeeId      String
  month           Int
  year            Int
  payslipNumber   String    @unique
  // Pay-period working days math
  monthDays       Int // calendar days in the period (28-31)
  workingDays     Int // monthDays minus weekly-offs + public holidays
  daysPresent     Decimal   @db.Decimal(5, 1)
  daysHalfDay     Decimal   @default(0) @db.Decimal(5, 1)
  daysOnPaidLeave Decimal   @db.Decimal(5, 1)
  daysLOP         Decimal   @db.Decimal(5, 1) // loss of pay
  // Money
  baseSalary      Decimal   @db.Decimal(12, 2) // Employee.salary at the time
  perDayRate      Decimal   @db.Decimal(12, 2)
  earnedGross     Decimal   @db.Decimal(12, 2)
  // Statutory + voluntary deductions stored as JSON for flexibility:
  //   { pf?: number, esi?: number, professionalTax?: number, tds?: number,
  //     loan?: number, other?: number }
  deductions      Json?
  totalDeductions Decimal   @default(0) @db.Decimal(12, 2)
  netPay          Decimal   @db.Decimal(12, 2)
  // Lifecycle
  status          String    @default("draft") // draft, finalized, paid, cancelled
  finalizedAt     DateTime?
  paidAt          DateTime?
  paidBy          String?
  paymentRef      String?
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([employeeId, month, year])
  @@index([tenantId])
  @@index([employeeId])
  @@map("payslips")
}

// ===========================
// DIALYSIS / NEPHROLOGY
// ===========================

// One physical dialysis machine/chair. Status reflects current state so
// scheduling can avoid double-booking and maintenance can be tracked.
model DialysisMachine {
  id            String            @id @default(uuid())
  tenantId      String
  branchId      String?
  machineName   String
  machineCode   String
  modality      String            @default("HD") // HD = haemodialysis, HDF, PD, SLED
  manufacturer  String?
  model         String?
  serialNumber  String?
  installDate   DateTime?
  lastServiceAt DateTime?
  status        String            @default("available") // available, in_use, maintenance, retired
  location      String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      DialysisSession[]

  @@unique([tenantId, machineCode])
  @@index([tenantId])
  @@map("dialysis_machines")
}

// One dialysis session for a patient. Pre/post weights + UF volume +
// session duration are the headline clinical numbers; vascular access
// type matters for nursing technique. Status drives the workflow:
// scheduled → in_progress → completed | cancelled.
model DialysisSession {
  id             String           @id @default(uuid())
  tenantId       String
  patientId      String
  machineId      String?
  nephrologistId String? // FK to User
  nurseId        String? // FK to User
  scheduledDate  DateTime
  scheduledTime  String?
  startedAt      DateTime?
  endedAt        DateTime?
  durationMin    Int? // typically 240 for HD
  modality       String           @default("HD")
  vascularAccess String? // AVF, AVG, central catheter (right IJ / fem), peritoneal
  dialyzer       String? // make + flux
  bloodFlowRate  Int? // ml/min, typical 250-400
  dialysateFlow  Int? // ml/min, typical 500
  ufGoalMl       Int? // ultrafiltration goal in mL
  ufActualMl     Int? // actually removed
  preWeightKg    Decimal?         @db.Decimal(5, 2)
  postWeightKg   Decimal?         @db.Decimal(5, 2)
  preBpSys       Int?
  preBpDia       Int?
  postBpSys      Int?
  postBpDia      Int?
  heparin        String? // dose + protocol
  complications  String?
  notes          String?
  status         String           @default("scheduled") // scheduled, in_progress, completed, cancelled, missed
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  machine        DialysisMachine? @relation(fields: [machineId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([scheduledDate])
  @@map("dialysis_sessions")
}

// ===========================
// MORTUARY
// ===========================

// Deceased registry + cold-storage tracking. Body number is what the
// hospital uses to identify the case (separate from the patient's MRN).
model MortuaryRecord {
  id              String    @id @default(uuid())
  tenantId        String
  patientId       String? // null for unidentified bodies
  bodyNumber      String
  deceasedName    String
  age             Int?
  gender          String?
  contact         String?
  dateOfDeath     DateTime
  causeOfDeath    String?
  doctorOnDuty    String? // FK to User but lazy
  fridgeUnit      String? // unit identifier within mortuary
  shelfNumber     String?
  storedAt        DateTime?
  releasedAt      DateTime?
  releasedTo      String? // family contact name + relationship
  releaseAuthBy   String? // who authorised release
  autopsyRequired Boolean   @default(false)
  autopsyAt       DateTime?
  autopsyFindings String?
  remarks         String?
  status          String    @default("stored") // stored, released, autopsy, transferred
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, bodyNumber])
  @@index([tenantId])
  @@map("mortuary_records")
}

// ===========================
// PHLEBOTOMY (sample collection rounds)
// ===========================

// A round = one phlebotomist's batch of collections during a shift.
// Individual sample collection links back to the existing Order model.
model PhlebotomyRound {
  id            String   @id @default(uuid())
  tenantId      String
  branchId      String?
  phlebotomist  String? // FK to User
  shift         String? // morning, afternoon, night
  scheduledDate DateTime
  area          String? // OPD, IPD ward, home-collection route
  totalSamples  Int      @default(0)
  collected     Int      @default(0)
  rejected      Int      @default(0)
  status        String   @default("planned") // planned, in_progress, completed
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([scheduledDate])
  @@map("phlebotomy_rounds")
}

// ===========================
// PHYSIOTHERAPY
// ===========================

// A treatment plan defines goals + protocol for a course of therapy.
// Sessions roll up to a plan; a plan can span weeks.
model PhysioPlan {
  id             String          @id @default(uuid())
  tenantId       String
  patientId      String
  therapistId    String? // FK to User
  diagnosis      String?
  goals          String?
  protocol       String? // exercises, modalities, frequency, duration
  totalSessions  Int             @default(10)
  completedCount Int             @default(0)
  startDate      DateTime
  endDate        DateTime?
  status         String          @default("active") // active, paused, completed, cancelled
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       PhysioSession[]

  @@index([tenantId])
  @@index([patientId])
  @@map("physio_plans")
}

model PhysioSession {
  id            String      @id @default(uuid())
  tenantId      String
  planId        String?
  patientId     String
  therapistId   String?
  scheduledDate DateTime
  scheduledTime String?
  durationMin   Int?
  modalities    String? // ultrasound, TENS, IFT, hot pack, exercises
  exercises     String?
  painPre       Int? // VAS 0-10
  painPost      Int?
  rangeOfMotion String?
  notes         String?
  status        String      @default("scheduled") // scheduled, completed, no_show, cancelled
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  plan          PhysioPlan? @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([scheduledDate])
  @@map("physio_sessions")
}

// ===========================
// CSSD (Central Sterile Supply Department)
// ===========================

// One sterilization cycle on an autoclave / ETO chamber. Items in the
// cycle are referenced by pack name (item-level tracking is a future
// iteration once barcode-on-pack is rolled out).
model SterilizationCycle {
  id                  String    @id @default(uuid())
  tenantId            String
  cycleNumber         String
  machineId           String? // autoclave / ETO machine
  machineName         String?
  cycleType           String // steam, ETO, plasma
  loadType            String? // instrument, linen, glassware
  startedAt           DateTime
  endedAt             DateTime?
  temperatureC        Decimal?  @db.Decimal(5, 1)
  pressureBar         Decimal?  @db.Decimal(4, 2)
  durationMin         Int?
  loadCount           Int?
  biologicalIndicator String? // pass, fail, pending
  chemicalIndicator   String? // pass, fail
  releasedBy          String?
  status              String    @default("running") // running, completed, failed, recalled
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([tenantId, cycleNumber])
  @@index([tenantId])
  @@map("sterilization_cycles")
}

model CSSDInstrument {
  id               String    @id @default(uuid())
  tenantId         String
  instrumentCode   String
  name             String
  category         String? // surgical, dental, ENT, etc.
  status           String    @default("available") // available, in_use, sterilizing, damaged, retired
  lastSterilizedAt DateTime?
  expiresAt        DateTime?
  location         String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, instrumentCode])
  @@index([tenantId])
  @@map("cssd_instruments")
}

// ===========================
// PATHOLOGY (specialized cases beyond routine lab)
// ===========================

// One pathology case: histopath, cytology, IHC, frozen section. Linked
// to a patient + referring doctor; specimens come in, get grossed,
// processed, examined, reported. Status drives the workflow.
model PathologyCase {
  id                  String    @id @default(uuid())
  tenantId            String
  caseNumber          String
  patientId           String
  referringDoctor     String? // FK to User but lazy
  pathologistId       String? // FK to User
  caseType            String // histopath, cytology, frozen_section, IHC, FNAC
  specimenSource      String? // skin, breast, GI, cervix, etc.
  clinicalHistory     String?
  grossDescription    String?
  microscopicFindings String?
  impression          String?
  ihcMarkers          Json? // array of { marker, result }
  receivedAt          DateTime  @default(now())
  reportedAt          DateTime?
  status              String    @default("received") // received, grossing, processing, examined, reported, amended
  priority            String    @default("routine") // routine, urgent, frozen
  remarks             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([tenantId, caseNumber])
  @@index([tenantId])
  @@index([patientId])
  @@map("pathology_cases")
}

// ===========================
// EQUIPMENT MAINTENANCE
// ===========================

// Maintenance ticket against an asset. Type covers preventive +
// corrective + AMC visits. Linked to existing Asset model so the asset
// page can show its maintenance history.
model MaintenanceTicket {
  id            String    @id @default(uuid())
  tenantId      String
  ticketNumber  String
  assetId       String? // FK to Asset (legacy; not all assets are in the model yet)
  assetName     String
  assetCategory String? // imaging, ICU, OT, lab
  type          String // preventive, corrective, calibration, amc
  priority      String    @default("normal") // urgent, normal, low
  reportedBy    String?
  assignedTo    String? // technician name or vendor
  vendor        String?
  reportedAt    DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  description   String
  rootCause     String?
  partsReplaced String?
  costAmount    Decimal?  @db.Decimal(10, 2)
  downtimeHours Decimal?  @db.Decimal(6, 2)
  status        String    @default("open") // open, in_progress, on_hold, completed, cancelled
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@map("maintenance_tickets")
}

// ===========================
// AMBULANCE MANAGEMENT
// ===========================

model AmbulanceVehicle {
  id              String    @id @default(uuid())
  tenantId        String
  vehicleNumber   String
  type            String // ALS, BLS, patient_transport
  driverName      String?
  driverPhone     String?
  status          String    @default("available") // available, on_trip, maintenance, out_of_service
  lastMaintenance DateTime?
  currentLocation String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, vehicleNumber])
  @@index([tenantId])
  @@map("ambulance_vehicles")
}

// ===========================
// EMERGENCY CASE TRACKING
// ===========================

model EmergencyCase {
  id             String    @id @default(uuid())
  tenantId       String
  patientId      String?
  patientName    String
  patientAge     Int?
  patientGender  String?
  patientContact String?
  arrivalTime    DateTime  @default(now())
  triageCategory String // RED, YELLOW, GREEN
  chiefComplaint String?
  vitalSigns     Json?
  isMLC          Boolean   @default(false)
  mlcNumber      String?
  assignedDoctor String?
  status         String    @default("active") // active, admitted, discharged, transferred
  disposition    String? // admitted_ipd, admitted_icu, discharged, transferred, dama, expired
  dischargeTime  DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@map("emergency_cases")
}

// ===========================
// ICU MANAGEMENT
// ===========================

model ICUBed {
  id             String      @id @default(uuid())
  tenantId       String
  bedNumber      String
  icuUnit        String // MICU, SICU, NICU, PICU, CCU
  status         String      @default("vacant") // vacant, occupied, maintenance
  currentPatient String?
  admissionId    String?
  ventilatorId   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  vitalsRecords  ICUVitals[]

  @@unique([tenantId, bedNumber])
  @@index([tenantId])
  @@map("icu_beds")
}

model ICUVitals {
  id              String   @id @default(uuid())
  tenantId        String
  icuBedId        String
  patientId       String?
  heartRate       Int?
  systolicBP      Int?
  diastolicBP     Int?
  temperature     Decimal? @db.Decimal(4, 1)
  spo2            Int?
  respiratoryRate Int?
  gcs             Int?
  ventilatorMode  String?
  fio2            Int?
  peep            Int?
  recordedAt      DateTime @default(now())
  recordedBy      String?
  icuBed          ICUBed   @relation(fields: [icuBedId], references: [id])

  @@index([tenantId])
  @@map("icu_vitals")
}

// ===========================
// SURGERY/OT MANAGEMENT
// ===========================

model Surgery {
  id                String    @id @default(uuid())
  tenantId          String
  patientId         String?
  patientName       String
  patientMRN        String?
  procedureName     String
  surgeonId         String?
  surgeonName       String
  anesthetistId     String?
  anesthetistName   String?
  otRoomId          String?
  otRoom            String?
  scheduledDate     DateTime
  scheduledTime     String?
  estimatedDuration Int? // minutes
  actualStartTime   DateTime?
  actualEndTime     DateTime?
  anesthesiaType    String?
  priority          String    @default("elective") // emergency, urgent, elective
  status            String    @default("scheduled") // scheduled, in_progress, completed, cancelled, postponed
  preOpChecklist    Boolean   @default(false)
  postOpNotes       String?
  complications     String?
  implants          Json?
  consumables       Json?
  // Fine-grained intra-OT stage so OT staff can broadcast "anesthesia done",
  // "surgery started", etc. to registered family contacts. Free-text, but the
  // FE/BE share a known list of canonical values (see services/surgeryStages.ts).
  currentStage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  stageEvents    SurgeryStageEvent[]
  familyContacts SurgeryFamilyContact[]

  @@index([tenantId])
  @@map("surgeries")
}

// Append-only log of every stage transition during a surgery. Drives both the
// staff-side timeline and the family-facing live tracker page.
model SurgeryStageEvent {
  id         String    @id @default(uuid())
  tenantId   String
  surgeryId  String
  stage      String // canonical stage code, e.g. "ANESTHESIA_DONE"
  note       String?
  recordedBy String // userId
  recordedAt DateTime  @default(now())
  notifiedAt DateTime?

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@index([surgeryId, recordedAt])
  @@index([tenantId])
  @@map("surgery_stage_events")
}

// Family members opted in to receive live status updates for a specific
// surgery. Each contact gets a unique (random, unguessable) trackingToken
// that grants read-only access to /track/surgery/:token without a login.
model SurgeryFamilyContact {
  id            String   @id @default(uuid())
  tenantId      String
  surgeryId     String
  name          String
  relation      String // 'spouse' | 'parent' | 'child' | 'sibling' | 'other'
  phone         String
  whatsapp      String?
  email         String?
  trackingToken String   @unique
  channels      String // CSV of 'sms','whatsapp','email'
  createdAt     DateTime @default(now())

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@index([surgeryId])
  @@index([tenantId])
  @@map("surgery_family_contacts")
}

model OTRoom {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  type           String // general, cardiac, neuro, orthopedic, etc.
  floor          String?
  status         String   @default("available") // available, in_use, cleaning, maintenance
  currentSurgery String?
  equipment      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("ot_rooms")
}
